# Reject DESI spectype=STAR when assigning a foreground redshift.
#
# Context: cluster J114928.5+712526 (phineas sightline, Wen+2024) picked up a
# foreground star inside its 90" centroid-match radius. The star's DESI spectrum
# (zwarn=0, spectype=STAR, z=-0.0001) outranked the real cluster redshift in
# best_z_and_verdict's priority chain, so the row displayed z=-0.000. Correct z
# is triangulated to ~0.156 (Wen 0.1574, LS DR9 photo-z 0.1559+/-0.0059 on the
# DEV-morphology BCG, NED 0.145).
#
# Two layers, both minimal:
#   1. q_desi   - exclude STAR spectra at the query so a star is never fetched.
#   2. best_z_and_verdict - defensive guard so re-deriving best_z/verdict from an
#      already-cached foreground_validated.csv (no re-query) also drops the star.
#
# QSO spectra are intentionally retained (a QSO at z<z_host is a genuine
# intervening absorber); only stellar contaminants are rejected.
#
# Apply from the dsa110-FLITS checkout that carries the untracked scratch scripts
# (e.g. the flits-rerun worktree):
#   git apply docs/rse/patches/patch-foreground-reject-star-specz.diff   # (adjust path)
#   # or, if the header lines trip git apply:  patch -p1 < <this-file>
# then regenerate:
#   python scratch/codetection/validate_foreground.py   # re-query, or re-derive offline
#   python scratch/codetection/merge_final.py
#   python scratch/codetection/make_catalog_table.py     # -> foreground_table.tex
# and refresh the pinned-submodule SSOT:
#   python -m galaxies.foreground.build_artifacts        # -> intervening_census_registry.csv
--- a/scratch/codetection/validate_foreground.py
+++ b/scratch/codetection/validate_foreground.py
@@ -97,7 +97,8 @@
         "SELECT mean_fiber_ra, mean_fiber_dec, z, zerr, zwarn, spectype "
         "FROM desi_dr1.zpix "
         f"WHERE mean_fiber_dec BETWEEN {d0} AND {d1} "
-        f"AND mean_fiber_ra BETWEEN {r0} AND {r1} AND zwarn = 0"
+        f"AND mean_fiber_ra BETWEEN {r0} AND {r1} AND zwarn = 0 "
+        "AND spectype != 'STAR'"  # a stellar velocity is never a foreground galaxy/cluster z
     )
     r = TAP.search(q).to_table()
     row, sep = _nearest(r, ra, dec, "mean_fiber_ra", "mean_fiber_dec", rad_as)
@@ -169,7 +170,9 @@
 def best_z_and_verdict(host_z, sheet_zphot, d):
     """Pick best redshift; return (best_z, source, verdict)."""
     # priority: DESI spec-z > LS z_spec > LS z_phot(+std) > NED z
-    if not np.isnan(d.get("desi_specz", np.nan)):
+    # A DESI STAR match is a foreground stellar contaminant, not the object's
+    # cosmological redshift -> skip it and fall through to LS/NED.
+    if not np.isnan(d.get("desi_specz", np.nan)) and str(d.get("desi_spectype", "")).strip() != "STAR":
         bz, src, std = d["desi_specz"], "desi_specz", 0.0
     elif not np.isnan(d.get("lsdr9_zspec", np.nan)):
         bz, src, std = d["lsdr9_zspec"], "lsdr9_zspec", 0.0
